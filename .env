# Configuración segura (Cámbialo a False en producción)
DEBUG=True
SECRET_KEY=django-insecure-tu-clave-secreta-cambiala-en-prod

# Base de datos (Formato: postgres://usuario:clave@host:puerto/nombre_db)
# En Docker el host es "db", el usuario "admin", clave "supersecreto"
DATABASE_URL=postgres://admin:supersecreto@db:5432/contrataciones_db

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1,web

# CORS (Quién puede consultar tu API)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000